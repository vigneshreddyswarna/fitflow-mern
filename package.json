{
  "name": "fitflow-mern",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "description": "A MERN fitness consistency and class booking platform",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"pnpm server\" \"pnpm client\"",
    "server": "nodemon server/index.js",
    "client": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "start": "node server/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format:check": "prettier --check \"**/*.{js,jsx,mjs,json,md,yml,yaml,css}\"",
    "smoke": "node server/scripts/smoke-production.js",
    "seed:admin": "node server/scripts/seed-admin.js",
    "seed:demo": "node server/scripts/seed-demo-users.js",
    "seed:classes": "node server/scripts/seed-classes.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.15.1",
    "nodemailer": "^9.0.1",
    "openai": "^5.8.2",
    "pino": "9.14.0",
    "pino-http": "10.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "recharts": "^2.15.3",
    "stripe": "^18.3.0",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@playwright/test": "1.57.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@vitejs/plugin-react": "^4.5.1",
    "@vitest/coverage-v8": "3.2.6",
    "concurrently": "^9.1.2",
    "eslint": "9.39.1",
    "eslint-plugin-react": "7.37.5",
    "globals": "16.5.0",
    "jsdom": "27.2.0",
    "nodemon": "^3.1.10",
    "prettier": "3.7.4",
    "supertest": "^7.1.1",
    "vite": "^6.3.5",
    "vitest": "^3.2.4"
  }
}
